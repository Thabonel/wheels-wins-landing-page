# ═══════════════════════════════════════════════════════════
# Wheels & Wins — Staging Environment
# ═══════════════════════════════════════════════════════════
# Copy: cp .env.staging.example .env.staging
# Never commit .env.staging

# ─── Staging Supabase (Separate Project) ───
SUPABASE_URL=https://[YOUR-STAGING-PROJECT].supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ─── Frontend (Netlify Staging) ───
VITE_SUPABASE_URL=https://[YOUR-STAGING-PROJECT].supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
VITE_ENVIRONMENT=staging
VITE_BACKEND_URL=https://wheels-wins-backend-staging.onrender.com
VITE_PAM_WEBSOCKET_URL=wss://wheels-wins-backend-staging.onrender.com/api/v1/pam/ws
VITE_USE_PAM_2=true

# ─── AI Provider ───
PAM_V2_ENABLED=true
PAM_V2_PROVIDER=openai
PAM_V2_MODEL=gpt-5.4-mini
OPENAI_API_KEY=sk-...

# ─── Required ───
SECRET_KEY=staging-secret-key-change-me
NODE_ENV=staging
DEBUG=true
